// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql" based on .env
  url      = env("DATABASE_URL")
}

model Client {
  id    Int     @id @default(autoincrement())
  phone String  @unique
  name  String
}

model Result {
  id        Int     @id @default(autoincrement())
  barcode   String  @unique
  phone     String
  status_id Int
  urls      Json?   // Array of objects with path0, name0, etc.
}

model QueryLog {
  id        Int      @id @default(autoincrement())
  phone     String
  barcode   String
  found     Boolean
  status_id Int?
  message   String?
  createdAt DateTime @default(now())
}